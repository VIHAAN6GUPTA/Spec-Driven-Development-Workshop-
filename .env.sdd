# Required: your email and app-specific password (not your login password)
EMAIL_ADDRESS=you@example.com
EMAIL_PASSWORD=your-app-password

# Optional IMAP overrides (auto-detected from domain if omitted)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# Optional: OpenAI-compatible API for better classification and reply drafts
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# How many recent INBOX messages to analyze (default 50)
MAX_MESSAGES=50

# Comma-separated sender addresses to treat as important
# IMPORTANT_SENDERS=boss@company.com,hr@company.com
